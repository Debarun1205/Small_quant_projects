# 4.  Visualisation helper
# ══════════════════════════════════════════════════════════════════════════════
def plot_contract(results_list, labels, output_path="/mnt/user-data/outputs/gas_contract_chart.png"):
    """Plot volume profile and cumulative P&L for one or more scenarios."""
    n = len(results_list)
    fig, axes = plt.subplots(n, 2, figsize=(15, 4.5 * n))
    if n == 1:
        axes = [axes]

    fig.patch.set_facecolor("#0d1117")
    BLUE, GREEN, RED, ORANGE = "#58a6ff", "#3fb950", "#f78166", "#e3b341"

    for idx, (res, label) in enumerate(zip(results_list, labels)):
        ax_vol, ax_cf = axes[idx]
        for ax in (ax_vol, ax_cf):
            ax.set_facecolor("#161b22")
            ax.tick_params(colors="#c9d1d9", labelsize=8)
            for spine in ax.spines.values():
                spine.set_edgecolor("#30363d")
            ax.grid(True, color="#21262d", lw=0.6)

        df = res["cashflow_table"].copy()
        df["Date"] = pd.to_datetime(df["Date"])
        df = df.sort_values("Date")

        # Volume profile (step)
        ax_vol.set_title(f"{label} — Volume in Storage", color="#e6edf3", fontsize=10, pad=6)
        dates_ext = list(df["Date"])
        vols_ext  = list(df["Volume Held After"])
        # prepend start
        if dates_ext:
            dates_ext = [dates_ext[0] - pd.Timedelta(days=1)] + dates_ext
            vols_ext  = [0] + vols_ext
        ax_vol.step(dates_ext, vols_ext, where="post", color=BLUE, lw=2)
        ax_vol.fill_between(dates_ext, vols_ext, step="post", alpha=0.18, color=BLUE)
        ax_vol.set_ylabel("MMBtu held", color="#c9d1d9", fontsize=9)
        ax_vol.xaxis.set_major_formatter(mdates.DateFormatter("%b %Y"))
        plt.setp(ax_vol.xaxis.get_majorticklabels(), rotation=25, ha="right", color="#c9d1d9")

        # Mark injection / withdrawal events
        for _, row in df.iterrows():
            color = GREEN if row["Event"] == "Inject" else RED
            ax_vol.axvline(row["Date"], color=color, lw=1.2, ls="--", alpha=0.6)
            ax_vol.text(row["Date"], ax_vol.get_ylim()[1] * 0.92,
                        "I" if row["Event"] == "Inject" else "W",
                        color=color, fontsize=7, ha="center")

        # Cumulative P&L bar chart
        ax_cf.set_title(f"{label} — Cumulative Cash Flows", color="#e6edf3", fontsize=10, pad=6)
        categories = ["Gross Revenue", "Gross Cost", "Storage Cost", "Contract Value"]
        values     = [res["gross_revenue"], -res["gross_cost"], -res["storage_cost"], res["contract_value"]]
        colors     = [GREEN, RED, ORANGE, BLUE if res["contract_value"] >= 0 else RED]
        bars = ax_cf.bar(categories, values, color=colors, alpha=0.85, width=0.5)
        for bar, val in zip(bars, values):
            ax_cf.text(bar.get_x() + bar.get_width()/2, bar.get_height() + (max(values)*0.01),
                       f"${val:,.0f}", ha="center", va="bottom", color="#c9d1d9", fontsize=8)
        ax_cf.axhline(0, color="#484f58", lw=0.8)
        ax_cf.set_ylabel("USD ($)", color="#c9d1d9", fontsize=9)
        ax_cf.tick_params(axis="x", colors="#c9d1d9", labelsize=8)

    plt.suptitle("Natural Gas Storage Contract Pricing", color="#e6edf3", fontsize=13, y=1.01)
    plt.tight_layout(pad=2)
    plt.savefig(output_path, dpi=150, bbox_inches="tight", facecolor=fig.get_facecolor())
    plt.close()
    print(f"Chart saved → {output_path}")


